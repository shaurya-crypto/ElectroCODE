{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.electroai.electrocode",
  "asar": true,
  "productName": "Electro CODE",
  "forceCodeSigning": false,
  "afterPack": "./scripts/afterPack.cjs",
  "directories": {
    "output": "release/${version}"
  },
  "files": [
    "dist",
    "dist-electron"
  ],
  "extraResources": [
    {
      "from": "../mcp-server",
      "to": "_internal/mcp-server",
      "filter": [
        "src/**/*",
        "package.json"
      ]
    },
    {
      "from": "../ai-engine",
      "to": "_internal/ai-engine",
      "filter": [
        "src/**/*",
        "package.json"
      ]
    },
    {
      "from": "../firmware-tools",
      "to": "_internal/firmware-tools",
      "filter": [
        "**/*",
        "!__pycache__/**",
        "!**/*.pyc"
      ]
    },
    {
      "from": "src/assets/icon.ico",
      "to": "icon.ico"
    }
  ],
  "mac": {
    "target": ["dmg", "zip"],
    "artifactName": "${productName}-Mac-${version}-${arch}.${ext}",
    "category": "public.app-category.developer-tools"
  },
  "win": {
      "icon": "src/assets/icon.ico",
      "target": [
        {
          "target": "nsis", // <-- Change this to nsis
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "deleteAppDataOnUninstall": false,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "ElectroCODE"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "category": "Development",
    "artifactName": "${productName}-Linux-${version}-${arch}.${ext}"
  },
  "npmRebuild": false
}